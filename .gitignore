# Node / build
node_modules/
out/
dist/
release/
*.tsbuildinfo
.vite/

# Env / secrets
.env
.env.local
.env.*.local

# App runtime data (config, chat sessions, usage) — machine-local, self-contained in the app folder.
data/

# Optional bundled portable Node (dropped in by hand on a machine with no Node installed).
node/

# Generated outputs from the agent: we DO commit these (they sync A<->B), but never big binaries.
*.psd
*.ai
*.mp4
*.mov
*.zip

# Documents the marketer uploads for the agent to read — local working area, not synced (can be big).
agent-workspace/uploads/*
!agent-workspace/uploads/.gitkeep

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Claude Code local-only settings
.claude/settings.local.json
.claude/.last_session*
.claude/shell-snapshots/
.claude/todos/

# Temp / scratch
*.tmp
~$*
*.bak
