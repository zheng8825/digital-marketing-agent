{
  "name": "marketing-agent-dashboard",
  "version": "0.1.0",
  "description": "Double-click local web UI: a marketing agent for ASUS Malaysia notebooks, running on Claude Code (Pro/Max) or Codex (ChatGPT Plus/Pro) with claude-mem long-term memory. Serves on localhost in your browser — nothing is installed.",
  "author": "zheng8825",
  "license": "UNLICENSED",
  "private": true,
  "main": "out/main/index.cjs",
  "scripts": {
    "icon": "node build/make-icon.mjs",
    "stop-icon": "node build/make-stop-icon.mjs",
    "fetch-node": "node build/fetch-node.mjs",
    "build:server": "node build/build-server.mjs",
    "build:web": "vite build",
    "build": "npm run build:web && npm run build:server",
    "dev:server": "cross-env PORT=8731 MARKETING_AGENT_NO_OPEN=1 tsx watch src/main/index.ts",
    "dev:web": "vite",
    "dev": "concurrently -k -n server,web \"npm:dev:server\" \"npm:dev:web\"",
    "start": "node out/main/index.cjs",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "cross-spawn": "^7.0.6",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0"
  },
  "devDependencies": {
    "@fontsource/dm-sans": "^5.1.0",
    "@fontsource/inter": "^5.2.8",
    "@types/cross-spawn": "^6.0.6",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.24.0",
    "lucide-react": "^0.460.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "engines": {
    "node": ">=20"
  }
}
